              <name>LINMTXDTIMEOUTDOMINANT</name>
              <description>Tx Dominant Timeout. The bit is set by LINM TxD monitor if LINM&#39;s TxD is stuck at dominant output for 64ms. A dominant to recessive transition of the TxD will clear this bit. LIN&#39;s TX will be disabled automatically when this bit is set.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>LEDPIN</name>
          <description>LED Pin Control</description>
          <addressOffset>0x0000003C</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>SENSE_ENA</name>
              <description>LED Forward Voltage Sense Enable. Set to enable LED forward voltage sense module. After setting this bit, it&#39;s recommended to wait ~40us before ADC conversion for LED_SENSE to settle down.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SENSE_CTRL</name>
              <description>LED. LED Sense Control bits for override control/debug.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>VFW_ENA</name>
              <description>LED Forward Voltage Current Enable. Set to enable the independent LED VFW current source(maximum=5mA). When ADC CH2 measurement is active, the LED channel selected by CH2_SEL will be driven by LED_VFW current source.</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>GAIN_SEL</name>
              <description>LED Sense AFE gain select. V_ADC = (vbat-vled)*GAIN , where V_ADC is voltage to ADC LED channle, and GAIN is selected by GAIN_SEL as following:&#10;0x0: GAIN = 2/5&#10;0x1: GAIN = 1/5</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PN_OP_START_BIAS_BOOST</name>
              <description>PN OP START BIAS BOOST. PN diff OP start bias current&#10;00: 1uA&#10;01: 2uA&#10;10: 3uA&#10;11: 4uA</description>
              <bitOffset>17</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>OP_GBW_SEL</name>
              <description>LED SENSE OP GBW SEL. PN detect fully differential Op GBW choose&#10;00: 3M&#10;01: 5M&#10;10: 8M&#10;11: 10M</description>
              <bitOffset>22</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BUCK_OUT_PORN_STS</name>
              <description>BUCK ouput volatage POR flag. 0: BUCKOUT &lt; 2.1V(typ)&#10;1: BUCKOUT &gt; 2.3V</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>LEDHWMODE</name>
          <description>LED HW mode</description>
          <addressOffset>0x00000040</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>HWMODE</name>
              <description>LED hardware mode. LED Hardware Mode Enable. Each bit controls the corresponding LED Channel respectively.&#10;0x0: Hardware Mode Disabled. LED_DATA register drives the LED Data Output pin. Read is not available on this pin.&#10;0x1: Hardware Mode Enabled. PWM_BARIUM peripheral drives the LED Data Output pin. Read is not available on this pin.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>24</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>LEDDATA</name>
          <description>LED Data Out</description>
          <addressOffset>0x00000044</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>LEDDATA</name>
              <description>LED Data Out. When the LED hardware mode is disabled, then the data in this register bit is used to drive the LED driver. Each bit controls the corresonding LED Channel respectively.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>24</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>LEDPUENA</name>
          <description>LED Data Out</description>
          <addressOffset>0x00000048</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>LEDPUENA</name>
              <description>LED Pullup Enable. Set to enable LED Pullup when no LED current source is connected.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>24</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>ANALOGTESTMUXOVERRIDE1</name>
          <description>Analog Testmux Override 1</description>
          <addressOffset>0x0000004C</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>ADC_CON_SEL</name>
              <description>Hardware/Firmware Select&#10;NOTE:The write operation of this field register takes effect by configuring &#39;SYSCTRLA_SFRS-&gt;DEBUG_ACCESS_KEY.DEBUG_ACCESS_KEY = 0x05&#39;.&#10;0x0: Hardware Controlled.&#10;0x1: ADC_CON_REG controls output.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>GPIO_CON_SEL</name>
              <description>Hardware/Firmware Select&#10;NOTE:The write operation of this field register takes effect by configuring &#39;SYSCTRLA_SFRS-&gt;DEBUG_ACCESS_KEY.DEBUG_ACCESS_KEY = 0x05&#39;.&#10;0x0: Hardware Controlled.&#10;0x1: GPIO_CON_REG controls output.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>ADC_SEL_SEL</name>
              <description>Hardware/Firmware Select&#10;NOTE:The write operation of this field register takes effect by configuring &#39;SYSCTRLA_SFRS-&gt;DEBUG_ACCESS_KEY.DEBUG_ACCESS_KEY = 0x05&#39;.&#10;0x0: Hardware Controlled.&#10;0x1: ADC_SEL_REG controls output.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>ADC_CON_REG</name>
              <description>Firmware Debug Value. Contains the output value when the ADC_CON_SEL firmware select bit is set.&#10;0x1: Select All shot to adc_ref(2.4V) for adc channel offset K&#10;0x2: Select adc_vinp= adc_refp, adc_vinn= vref_gnd&#10;0x4: Select adc_vinp= vref_gnd, adc_vinn= adc_refp&#10;0x8: Select GPIO6(adc_vinp)/GPIO7(adc_vinn) to ADC&#10;0x10: Select Tempsensor to ADC&#10;0x20: Select VDD1.5v to ADC&#10;0x40: Select VDD3.3v to ADC&#10;0x80: Select VDD5.0v(1/4) to ADC&#10;0x100: Select Accurate VBAT to ADC&#10;0x200: Select GPIO1~9(determined by CH4_SEL in ADC_CTRL) to ADC&#10;0x400: Select BUCK 5V(1/4) to ADC&#10;0x800: Select LED0~23 Forward Voltage to ADC</description>
              <bitOffset>8</bitOffset>
              <bitWidth>12</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>ADC_GPIO_REG</name>
              <description>Select which GPIO forward voltage to ADC by firmware. Control which GPIO channel is selected when the ADC_CON_SEL/ADC_CON_REG[9] are set.&#10;0x0: Select GPIO6&#10;0x1: Select GPIO7&#10;0x2: Select GPIO8&#10;0x3: Select GPIO1&#10;0x4: Select GPIO2&#10;0x5: Select GPIO3&#10;0x6: Select GPIO4&#10;0x7: Select GPIO5&#10;0x8: Select GPIO9</description>
              <bitOffset>20</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>ADC_LED_REG</name>
              <description>Select which channel of LED forward voltage to ADC by firmware. Control which LED channel is selected when the ADC_CON_SEL/ADC_CON_REG[11] are set.</description>
              <bitOffset>24</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>ANALOGTESTMUXOVERRIDE2</name>
          <description>Analog Testmux Override 2</description>
          <addressOffset>0x00000050</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>GPIOCONREG</name>
              <description>Firmware Debug Value. GPIO1~9 test MUX select. ADC_SEL_SEL/ADC_SEL_REG need to be configured at the same time to enable required GPIO connection.&#10;0x1: Select VDD 3.3V digital supply to GPIO6, mutually exclusive with HVBUCK_ATB01.&#10;0x2: Select 1.5v MCU supply to GPIO6, mutually exclusive with HVBUCK_ATB01.&#10;0x4: Select VDD_PRE5V/4 to GPIO6, mutually exclusive with HVBUCK_ATB01.&#10;0x8: Select BUCK_5V/4 to GPIO6, mutually exclusive with HVBUCK_ATB01.&#10;0x10: Select ADC_REFP to GPIO7, mutually exclusive with HVBUCK_ATB02 and PMU_ATB.&#10;0x20: Select ADC_INP to GPIO7, mutually exclusive with HVBUCK_ATB02 and PMU_ATB.&#10;0x40: Select ADC_INN to GPIO8, mutually exclusive with PMU_ATB1, mutually exclusive with lin_ibg1up_tp.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>7</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>ADCSELREG</name>
              <description>Firmware Debug Value. Need to be configured with gpio_con_reg to enable gpio analog output to ADC.&#10;0x1: Enable GPIO1 analog connection&#10;0x2: Enable GPIO2 analog connection&#10;0x4: Enable GPIO3 analog connection&#10;0x8: Enable GPIO4 analog connection&#10;0x10: Enable GPIO5 analog connection&#10;0x20: Enable GPIO6 analog connection&#10;0x40: Enable GPIO7 analog connection&#10;0x80: Enable GPIO8 analog connection&#10;0x100: Enable GPIO9 analog connection</description>
              <bitOffset>16</bitOffset>
              <bitWidth>9</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>ANALOGTESTMUXOVERRIDE3</name>
          <description>Analog Testmux Override 3</description>
          <addressOffset>0x00000054</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>LEDSEL</name>
              <description>LED test analog channel select, one hot code&#10;NOTE:exclusive with DFT_MODE_ENA_LED.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>24</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>IRQ</name>
          <description>IOCTRLA LINS/LINM TXD Dominant Monitor interrupts</description>
          <addressOffset>0x00000058</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>INT_LINS_TXD_DOM_ENA</name>
              <description>LINS TXD Dominant Monitor interrupt enable.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>INT_LINM_TXD_DOM_ENA</name>
              <description>LINM TXD Dominant Monitor interrupt enable.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>INT_LINS_TXD_DOM_CLR</name>
              <description>LINS TXD Dominant Monitor interrupt clear.&#10;Autoclear: includes a synchronous reset signal which clears the register on the cycle following write.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>INT_LINM_TXD_DOM_CLR</name>
              <description>LINM TXD Dominant Monitor interrupt clear.&#10;Autoclear: includes a synchronous reset signal which clears the register on the cycle following write.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>INT_LINS_TXD_DOM_STS</name>
              <description>LINS TXD Dominant Monitor interrupt status.</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_LINM_TXD_DOM_STS</name>
              <description>LINM TXD Dominant Monitor interrupt status.</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_LINS_TXD_DOM_IRQ</name>
              <description>LINS TXD Dominant Monitor interrupt active.</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_LINM_TXD_DOM_IRQ</name>
              <description>LINM TXD Dominant Monitor interrupt active.</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>FILT_ACCESS</name>
          <description>Glitch Filter access key</description>
          <addressOffset>0x0000005C</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>FILT_UNLOCK</name>
              <description>Set Only bit. Write 1 to this bit to un-lock FILT_CODE bits.</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>MCU_INF_CONF</name>
          <description>Mcu interface access config</description>
          <addressOffset>0x00000060</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>MCU_CLK_SL</name>
              <description>mcu clock slew rate control: 0-fast 1-slow</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>MCU_INT_SL</name>
              <description>mcu int slew rate control: 0-fast 1-slow</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>MCU_DATA_SL</name>
              <description>mcu data slew rate control: 0-fast 1-slow</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>MCU_CLK_PDRV</name>
              <description>mcu clock drive strength control: 0-4mA 1-8mA 2-12mA 3-16mA</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>MCU_INT_PDRV</name>
              <description>mcu int drive strength control: 0-4mA 1-8mA 2-12mA 3-16mA</description>
              <bitOffset>10</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>MCU_DATA_PDRV</name>
              <description>mcu data drive strength control: 0-4mA 1-8mA 2-12mA 3-16mA</description>
              <bitOffset>12</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>SYSCTRLA</name>
      <version>B0</version>
      <description>System configuration and retention memory</description>
      <groupName>SYSCTRLA</groupName>
      <prependToName>SYSCTRLA_</prependToName>
      <baseAddress>0x50013000</baseAddress>
      <addressBlock>
        <offset>0</offset>
        <size>0x1000</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>RETAIN1</name>
          <description>Retained data 1</description>
          <addressOffset>0x00000000</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>RETAIN1</name>
              <description>Firmware scratch register 1 (0x1). Contents retained in Hibernate mode - but lost after any hard or soft reset.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>DEBUG_ACCESS_KEY</name>
          <description>Debug access key</description>
          <addressOffset>0x00000004</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>DEBUG_ACCESS_KEY</name>
              <description>Write the value 0x5 to this register to enable debug options. Write any other value to disable the debug options.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DEBUG_LOCK</name>
              <description>Set Only bit. Set this bit to lock DEBUG_CODE bits.</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>DEBUG_ACCESS_ENABLED</name>
          <description>Debug access enabled</description>
          <addressOffset>0x00000008</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>DEBUG_ACCESS_ENABLED</name>
              <description>A status flag that is set when debug access is enabled</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>TRIM_ACCESS_KEY</name>
          <description>Trim access key</description>
          <addressOffset>0x0000000C</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>TRIM_ACCESS_KEY</name>
              <description>Write the value 0xe to this register to enable &#39;trim access&#39; (which allows write access to various trim settings and production test options). Write any other value to disable trim access.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TRIM_LOCK</name>
              <description>Set Only bit. Write 1 to this bit to lock TRIM_CODE bits.</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>TRIM_ACCESS_ENABLED</name>
          <description>Trim access enabled</description>
          <addressOffset>0x00000010</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>TRIM_ACCESS_ENABLED</name>
              <description>A status flag that is set when trim access is enabled</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>PMU_ACCESS_KEY</name>
          <description>PMU configure access key</description>
          <addressOffset>0x00000014</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>PMU_ACCESS_KEY</name>
              <description>Write the value 0xA to this register to enable 1v5 domain at hibernate. Write any other value to disable the 1v5 domain at hibernate.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PMU_LOCK</name>
              <description>Set Only bit. Set this bit to lock PMU_CODE bits.</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>PMU_ACCESS_ENABLED</name>
          <description>PMU configure access enabled</description>
          <addressOffset>0x00000018</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>PMU_ACCESS_ENABLED</name>
              <description>A status flag that is set when pmu access is enabled</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>HF_OSC_TRIM</name>
          <description>Trim controls for the high frequency (16MHz) oscillator</description>
          <addressOffset>0x0000001C</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>TRIM_HF_RC</name>
              <description>High Frequency RC Oscillator trim. TRIM bits will be changed if SSC is enabled. Reload the trim bits from Flash if SSC is disabled while the change has happened. Following value only used as a reference:&#10;0xa: freq=26.08Mhz&#10;0x80: freq=9.62Mhz&#10;0xfa: freq=5.94Mhz</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SSCENA</name>
              <description>SSC Enable.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SSCDEEP</name>
              <description>SSC Depth Configuration.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SSCDIV</name>
              <description>SSC Clock Divider. SSC Freq = SYS_FREQ/[(SSC_DIV+1)*(SSC_DEEP+1)*4].</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>BIAS</name>
          <description>Bias Control</description>
          <addressOffset>0x00000020</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>LEDBIASSEL</name>
              <description>High Voltage LED bias select.&#10;0x0: The LED Bias is enabled and disabled by the pmu hardware state machine by default.&#10;0x1: The value of the LED_BIAS_REG field is what is used to drive the LED_BIAS signal. (override mode)</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LEDBIASREG</name>
              <description>High Voltage LED bias select register. If LED_BIAS_SEL is set, then LED_BIAS_REG allows override access to the LED BIAS signal.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LEDBIASTRIMEN</name>
              <description>LED bias trim eanble.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LEDBIASTRIM</name>
              <description>LED bias current trim. Each code is about 50nA step.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>TRIMLED0</name>
          <description>High Voltage LED trim</description>
          <addressOffset>0x00000024</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>TRIM0</name>
              <description>LED trim (100uA step).</description>
              <bitOffset>16</bitOffset>
