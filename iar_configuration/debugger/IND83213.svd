    <peripheral>
      <name>GPIO</name>
      <version>B0</version>
      <description>GPIO bit control and configuration</description>
      <groupName>GPIO</groupName>
      <prependToName>GPIO_</prependToName>
      <baseAddress>0x50014000</baseAddress>
      <addressBlock>
        <offset>0</offset>
        <size>0x1000</size>
