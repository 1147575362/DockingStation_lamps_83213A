              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>INT_FRMERR_ENA</name>
              <description>Framing error Interrupt Enable.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>INT_PRTYERR_ENA</name>
              <description>Parity Error Interrupt Enable.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>INT_BREAKKERR_ENA</name>
              <description>Break Error Interrupt Enable.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>INT_TXDONE_ENA</name>
              <description>Transmission done Interrupt Enable.</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>INT_RXMULTDONE_ENA</name>
              <description>Multiple Receive Transactions Done Interrupt Enable.</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>INT_TXMULTDONE_ENA</name>
              <description>Multiple Transmit Transactions Done Interrupt Enable.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>INT_RXDONE_CLR</name>
              <description>Rx Data ready Interrupt Clear.&#10;Autoclear: includes a synchronous reset signal which clears the register on the cycle following write.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>INT_OVRUNERR_CLR</name>
              <description>Overrun error Interrupt Clear.&#10;Autoclear: includes a synchronous reset signal which clears the register on the cycle following write.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>INT_FRMERR_CLR</name>
              <description>Framing error Interrupt Clear.&#10;Autoclear: includes a synchronous reset signal which clears the register on the cycle following write.</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>INT_PRTYERR_CLR</name>
              <description>Parity Error Interrupt Clear.&#10;Autoclear: includes a synchronous reset signal which clears the register on the cycle following write.</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>INT_BREAKKERR_CLR</name>
              <description>Break Error Interrupt Clear.&#10;Autoclear: includes a synchronous reset signal which clears the register on the cycle following write.</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>INT_TXDONE_CLR</name>
              <description>Transmission done Interrupt Clear.&#10;Autoclear: includes a synchronous reset signal which clears the register on the cycle following write.</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>INT_RXMULTDONE_CLR</name>
              <description>Multiple Receive Transactions Done Interrupt Clear.&#10;Autoclear: includes a synchronous reset signal which clears the register on the cycle following write.</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>INT_TXMULTDONE_CLR</name>
              <description>Multiple Transmit Transactions Done Interrupt Clear.&#10;Autoclear: includes a synchronous reset signal which clears the register on the cycle following write.</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>INT_RXDONE_STS</name>
              <description>Rx Data ready. Set by the UART when Rx data is ready</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_OVRUNERR_STS</name>
              <description>Overrun error. Set by the UART when an overrun error occurs</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_FRMERR_STS</name>
              <description>Framing error. Set by the UART when a framing error occurs</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_PRTYERR_STS</name>
              <description>Parity Error. Set by the UART when a parity error occurs</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_BREAKKERR_STS</name>
              <description>Break IRQ. Set by the UART when a break error occurs</description>
              <bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_TXDONE_STS</name>
              <description>Transmission is done. Set by the UART when the transmit is done</description>
              <bitOffset>21</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_RXMULTDONE_STS</name>
              <description>Multiple Receive Transactions Done. Set by the UART when the programmed number of receive transactions have completed. See UART_FIFO_LEVEL_CTL register</description>
              <bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_TXMULTDONE_STS</name>
              <description>Multiple Transmit Transactions Done. Set by the UART when the programmed number of transmit transactions have completed. See UART_FIFO_LEVEL_CTL register.</description>
              <bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_RXDONE_IRQ</name>
              <description>Rx Data ready Interrupt. Set by the UART when Rx data is ready</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_OVRUNERR_IRQ</name>
              <description>Overrun error Interrupt. Set by the UART when an overrun error occurs</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_FRMERR_IRQ</name>
              <description>Framing error Interrupt. Set by the UART when a framing error occurs</description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_PRTYERR_IRQ</name>
              <description>Parity Error Interrupt. Set by the UART when a parity error occurs</description>
              <bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_BREAKKERR_IRQ</name>
              <description>Break Error Interrupt. Set by the UART when a break error occurs</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_TXDONE_IRQ</name>
              <description>Transmission done Interrupt. Set by the UART when the transmission is done</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_RXMULTDONE_IRQ</name>
              <description>Multiple Receive Transactions Done Interrupt. Set by the UART when the programmed number of receive transactions have completed. See UART_FIFO_LEVEL_CTL register</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_TXMULTDONE_IRQ</name>
              <description>Multiple Transmit Transactions Done Interrupt. Set by the UART when the programmed number of transmit transactions have completed. See UART_FIFO_LEVEL_CTL register.</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>UARTINT2</name>
          <description>Extended UART Interrupts</description>
          <addressOffset>0x00000010</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>INT_RXTOUT_ENA</name>
              <description>Rx Time-out Interrupt Enable.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>INT_RXTOUT_CLR</name>
              <description>Rx Time-out Interrupt Clear.&#10;Autoclear: includes a synchronous reset signal which clears the register on the cycle following write.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>INT_RXTOUT_STS</name>
              <description>Rx Time-out. Set by the UART when timeout of 4 data frame times without reception, and data received(one or three bytes received,programmable)</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_RXTOUT_IRQ</name>
              <description>Rx Time-out Interrupt. Set by the UART when RXTOUT flag is set and RXOUT interrupt is enabled.</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>UARTBAUD</name>
          <description>UART Baud rate</description>
          <addressOffset>0x00000014</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>BAUDDIV</name>
              <description>Baud rate divider.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>OSR</name>
              <description>Over-sampling ratio. Valid OSR Range: 6 to 16.</description>
              <bitOffset>16</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>FDIV</name>
              <description>Fractional divider.</description>
              <bitOffset>24</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>UADVANCE</name>
              <description>Advance Register. Advances the sample window by 1 cycle. For Debug.</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>URETARD</name>
              <description>Retard Register. Retards the sample window by 1 cycle. For Debug.</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>UARTFIFOSTATUS</name>
          <description>UART FIFO STATUS</description>
          <addressOffset>0x00000018</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>RXUF</name>
              <description>Reception FIFO underflow.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>RXEMPTY</name>
              <description>Reception FIFO empty.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>RXFULL</name>
              <description>Reception FIFO empty.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>RXCOUNT</name>
              <description>Reception FIFO current count.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>6</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>TXOF</name>
              <description>Transmit FIFO overflow.</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>TXEMPTY</name>
              <description>Transmit FIFO empty.</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>TXFULL</name>
              <description>Transmit FIFO full.</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>TXCOUNT</name>
              <description>Transmit FIFO current count.</description>
              <bitOffset>24</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>UARTFIFOLEVELCTL</name>
          <description>UART FIFO Level Control</description>
          <addressOffset>0x0000001C</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>RXMULTIPLEXFERDONECNT</name>
              <description>Receive Data Count Interrupt. Minimum number of bytes in the receive FIFO before a INT_RX_MULTIPLE_XFER_DONE interrupt is asserted.&#10;Example: A value of 4 would be used to compare to the number of receive transactions (pushes to the Rx FIFO).&#10;Valid Range: 1 to 32,&#10;NOTE: Invalid configuration value &#39;0&#39; will be forced to &#39;1&#39;</description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TXMULTIPLEXFERDONECNT</name>
              <description>Transmit Data Count Interrupt. Number of bytes transmitted from the transmit FIFO before a INT_TX_MULTIPLE_XFER_DONE interrupt is asserted.&#10;Example: A value of 4 would be used to compare to the number of completed transfers (pops from the Tx FIFO).&#10;Valid Range: 1 to 8,&#10;NOTE: Invalid configuration value &#39;0&#39; will be forced to &#39;1&#39;</description>
              <bitOffset>8</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>PWM_AUX</name>
      <version>B0</version>
      <description>Control (and status) registers for the pulse width modulation waveform generator.</description>
      <groupName>PWM_AUX</groupName>
      <prependToName>PWM_AUX_</prependToName>
      <baseAddress>0x50010900</baseAddress>
      <addressBlock>
        <offset>0</offset>
        <size>0x0100</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>BASE0</name>
          <description>Base 0 functions</description>
          <addressOffset>0x00000000</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>PRESCALESEL0</name>
              <description>Prescaler select. Defines the ratio between the system clock and the clock used for the waveform generator.&#10;0x0: Divide by 1&#10;0x1: Divide by 2&#10;0x2: Divide by 4&#10;0x3: Divide by 8&#10;0x4: Divide by 16&#10;0x5: Divide by 64&#10;0x6: Divide by 256&#10;0x7: Divide by 1024</description>
              <bitOffset>8</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PERIOD0</name>
              <description>Period. Specifies the period of the output waveform in terms of a number of prescaler output cycles.</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>PWMCNT0</name>
          <description>PWM Count Value</description>
          <addressOffset>0x00000004</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>PWMCNT0</name>
              <description>PWM counter value to give a sense about the current period</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>BASE1</name>
          <description>Base 1 functions</description>
          <addressOffset>0x00000008</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>PRESCALESEL1</name>
              <description>Prescaler select. Defines the ratio between the system clock and the clock used for the waveform generator.&#10;0x0: Divide by 1&#10;0x1: Divide by 2&#10;0x2: Divide by 4&#10;0x3: Divide by 8&#10;0x4: Divide by 16&#10;0x5: Divide by 64&#10;0x6: Divide by 256&#10;0x7: Divide by 1024</description>
              <bitOffset>8</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PERIOD1</name>
              <description>Period. Specifies the period of the output waveform in terms of a number of prescaler output cycles.</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>PWMCNT1</name>
          <description>PWM Count Value</description>
          <addressOffset>0x0000000C</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>PWMCNT1</name>
              <description>PWM counter value to give a sense about the current period</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>BASESEL</name>
          <description>Base Timer Select for individual Channels</description>
          <addressOffset>0x00000010</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>BASE_SEL</name>
              <description>Base Timer Selects:1=Select BASE1, 0=Select BASE0.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>ENAREQ</name>
          <description>Enable request</description>
          <addressOffset>0x00000014</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>ENAREQ</name>
              <description>Set to enable the waveform generator.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>ENAREQALL</name>
              <description>Write 1 to enable all ENA_REQ bits; Write 0 has no effects.</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>CLRREQALL</name>
              <description>Write 1 to clear all ENA_REQ bits; Write 0 has no effects.</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>FORCEINACTIVE</name>
              <description>Set to force PWM signals return to initial value immediately.</description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>ENASTS</name>
          <description>Enable status</description>
          <addressOffset>0x00000018</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>ENASTS</name>
              <description>Status of enable in the waveform generator.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>INIT</name>
          <description>Intial State of Outputs</description>
          <addressOffset>0x0000001C</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>INIT</name>
              <description>Set to initialise the output waveform.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>INV</name>
          <description>Invert</description>
          <addressOffset>0x00000020</addressOffset>
