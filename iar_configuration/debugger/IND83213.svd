              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>INT_EFUSE0_DONE_ENA</name>
              <description>EFUSE macro0 done interrupt enable.</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>INT_EFUSE1_DONE_ENA</name>
              <description>EFUSE macro1 done interrupt enable.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>INT_START_ERROR_CLR</name>
              <description>BUCK start error interrupt clear.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>INT_VIN_UV_CLR</name>
              <description>Vin under-voltage interrupt clear.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>INT_VOUT_SHORT_CLR</name>
              <description>Vout short interrupt clear.</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>INT_VOUT_OK_CLR</name>
              <description>Vout soft start OK interrupt clear.</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>INT_VOUT_OV_CLR</name>
              <description>Vout over-voltage interrupt clear.</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>INT_VOUT_OC_CLR</name>
              <description>Vout over-current interrupt clear.</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>INT_EFUSE0_DONE_CLR</name>
              <description>EFUSE macro0 done interrupt clear.</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>INT_EFUSE1_DONE_CLR</name>
              <description>EFUSE macro1 done interrupt clear.</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>INT_START_ERROR_STS</name>
              <description>BUCK start error interrupt status.</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_VIN_UV_STS</name>
              <description>Vin under-voltage interrupt status.</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_VOUT_SHORT_STS</name>
              <description>Vout short interrupt status.</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_VOUT_OK_STS</name>
              <description>Vout soft start OK interrupt status.</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_VOUT_OV_STS</name>
              <description>Vout over-voltage interrupt status.</description>
              <bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_VOUT_OC_STS</name>
              <description>Vout over-current interrupt status.</description>
              <bitOffset>21</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_EFUSE0_DONE_STS</name>
              <description>EFUSE macro0 done interrupt status.</description>
              <bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_EFUSE1_DONE_STS</name>
              <description>EFUSE macro1 done interrupt status.</description>
              <bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_START_ERROR_IRQ</name>
              <description>BUCK start error interrupt activity.</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_VIN_UV_IRQ</name>
              <description>Vin under-voltage interrupt activity.</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_VOUT_SHORT_IRQ</name>
              <description>Vout short interrupt activity.</description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_VOUT_OK_IRQ</name>
              <description>Vout soft start OK interrupt activity.</description>
              <bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_VOUT_OV_IRQ</name>
              <description>Vout over-voltage interrupt activity.</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_VOUT_OC_IRQ</name>
              <description>Vout over-current interrupt activity.</description>
              <bitOffset>29</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_EFUSE0_DONE_IRQ</name>
              <description>EFUSE macro0 done interrupt activity.</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_EFUSE1_DONE_IRQ</name>
              <description>EFUSE macro1 done interrupt activity.</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>SAR_CTRL</name>
      <version>B0</version>
      <description>SAR ADC Interface registers</description>
      <groupName>SAR_CTRL</groupName>
      <prependToName>SAR_CTRL_</prependToName>
      <baseAddress>0x50010600</baseAddress>
      <addressBlock>
        <offset>0</offset>
        <size>0x0100</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>SAR_CTRL</name>
          <description>SAR ADC Control</description>
          <addressOffset>0x00000000</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>SAR_ENA_REQ</name>
              <description>SAR ADC Enable. Set to enable the SAR analog &amp; digital part</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SAR_PREAMP_EN</name>
              <description>adc pre-amp enable.&#10;0:disable,&#10;1:enable</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SAR_AFE_EN</name>
              <description>ADC AFE Enable. adc afe enable. If vinp, vinn and vin vcm all choose external, adc afe should be disabled: adc_adc_en=0, otherwise, adc afe must be enabled: adc_afe_en=1.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CONVERT</name>
              <description>ADC START Register. Set 1 to start a new adc conversion. NOTE: THAT BIT SHOULD NOT BE SET UNTIL ALL OTHER CONFIG BITS BE SETTED&#10;Autoclear: includes a synchronous reset signal which clears the register on the cycle following write.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>DIG_RESET</name>
              <description>SAR Digital Part Reset. Resets SAR digital parts.&#10;Autoclear: includes a synchronous reset signal which clears the register on the cycle following write.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>SAR_BUSY</name>
              <description>SAR ADC busy. When SAR ADC is running, the flag is set</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>CONT</name>
              <description>Continuous Conversion Enable. If this bit has been set before an ADC conversion sequence trigged by CONVERT bit, the sequence will be treated as a sequential conversion, rather than a single conversion, only value when auto_trg_en is disable.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>AVER_SEL</name>
              <description>Select average numbers of adc sample data.&#10;0x0: Average numbers of adc sample data: 4&#10;0x1: Average numbers of adc sample data: 8&#10;0x2: Average numbers of adc sample data: 16&#10;0x3: Average numbers of adc sample data: 32</description>
              <bitOffset>12</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>EN_AVER</name>
              <description>Enable sample data average.</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PWMSEL</name>
              <description>PWM Trigger Signal Selects. Selects the source PWM channel.</description>
              <bitOffset>16</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TRIGSEL</name>
              <description>SAR Converion Trigger Selects. Selects the trigger condition of SAR ADC. Don&#39;t change the bits during an ADC conversion sequence is ongoing.&#10;0x1: Triggered through writing 1 to conversion bit.&#10;0x2: Triggered by the PWM posedge.&#10;0x4: Triggered by the PWM negedge.&#10;0x8: Triggered by PWM period.</description>
              <bitOffset>24</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>ADC_SEL_VIN_VCM_EXT</name>
              <description>Select External Inputs to ADC. choose ADC input common voltage. 0: choose internal vin_vcm, equals to (vinp+vinn)/2; 1: choose external vin_vcm, for PN detect.</description>
              <bitOffset>28</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SAR_CFG0</name>
          <description>SAR Configuration Register0</description>
          <addressOffset>0x00000004</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>ADC_VREF_SEL_CH1</name>
              <description>adc vref select for channel 1.&#10;0x0: adc_vref = vbg when sar_ena_req=1&#10;0x1: adc_vref = 2*vbg when sar_ena_req=1&#10;0x2: adc_vref = VDD_3V3 when sar_ena_req=1&#10;0x3: adc_vref = VDD_3V3 when sar_ena_req=1</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>ADC_VREF_SEL_CH2</name>
              <description>adc vref select for channel 2.&#10;0x0: adc_vref = vbg when sar_ena_req=1&#10;0x1: adc_vref = 2*vbg when sar_ena_req=1&#10;0x2: adc_vref = VDD_3V3 when sar_ena_req=1&#10;0x3: adc_vref = VDD_3V3 when sar_ena_req=1</description>
              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>ADC_VREF_SEL_CH3</name>
              <description>adc vref select for channel 3.&#10;0x0: adc_vref = vbg when sar_ena_req=1&#10;0x1: adc_vref = 2*vbg when sar_ena_req=1&#10;0x2: adc_vref = VDD_3V3 when sar_ena_req=1&#10;0x3: adc_vref = VDD_3V3 when sar_ena_req=1</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>ADC_VREF_SEL_CH4</name>
              <description>adc vref select for channel 4.&#10;0x0: adc_vref = vbg when sar_ena_req=1&#10;0x1: adc_vref = 2*vbg when sar_ena_req=1&#10;0x2: adc_vref = VDD_3V3 when sar_ena_req=1&#10;0x3: adc_vref = VDD_3V3 when sar_ena_req=1</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SAR_INPUT_GAIN_CH1</name>
              <description>choose ADC input gain for channel 1.&#10;0x0: 14/32&#10;0x1: 22/32&#10;0x2: 31/32&#10;0x3: 31/32</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SAR_INPUT_GAIN_CH2</name>
              <description>choose ADC input gain for channel 2.&#10;0x0: 14/32&#10;0x1: 22/32&#10;0x2: 31/32&#10;0x3: 31/32</description>
              <bitOffset>10</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SAR_INPUT_GAIN_CH3</name>
              <description>choose ADC input gain for channel 3.&#10;0x0: 14/32&#10;0x1: 22/32&#10;0x2: 31/32&#10;0x3: 31/32</description>
              <bitOffset>12</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SAR_INPUT_GAIN_CH4</name>
              <description>choose ADC input gain for channel 4.&#10;0x0: 14/32&#10;0x1: 22/32&#10;0x2: 31/32&#10;0x3: 31/32</description>
              <bitOffset>14</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SAR_INPUT_MODE_CH1</name>
              <description>ADC AFE Input Modes for channel 1. Select ADC AFE Input Modes.&#10;0x0: All external.&#10;0x1: VINP buffered, VINN external.&#10;0x2: VINN buffered, VINP external.&#10;0x3: Both VINP &amp; VINN buffered.</description>
              <bitOffset>16</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SAR_INPUT_MODE_CH2</name>
              <description>ADC AFE Input Modes for channel 2. Select ADC AFE Input Modes.&#10;0x0: All external.&#10;0x1: VINP buffered, VINN external.&#10;0x2: VINN buffered, VINP external.&#10;0x3: Both VINP &amp; VINN buffered.</description>
              <bitOffset>18</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SAR_INPUT_MODE_CH3</name>
              <description>ADC AFE Input Modes for channel 3. Select ADC AFE Input Modes.&#10;0x0: All external.&#10;0x1: VINP buffered, VINN external.&#10;0x2: VINN buffered, VINP external.&#10;0x3: Both VINP &amp; VINN buffered.</description>
              <bitOffset>20</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SAR_INPUT_MODE_CH4</name>
              <description>ADC AFE Input Modes for channel 4. Select ADC AFE Input Modes.&#10;0x0: All external.&#10;0x1: VINP buffered, VINN external.&#10;0x2: VINN buffered, VINP external.&#10;0x3: Both VINP &amp; VINN buffered.</description>
              <bitOffset>22</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SAR_CFG1</name>
          <description>SAR Configuration Register1</description>
          <addressOffset>0x00000008</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>ROUND</name>
              <description>ADC round enable. Enable ADC round.&#10;0x0: No round.&#10;0x1: Negative code+1</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SAMPCYC_CH1</name>
              <description>Sample cycle for channel 1. Set sampling time from 1 to 16 sar clock cycles.&#10;0x0: 1 Cycle&#10;0x1: 2 Cycle&#10;0x2: 3 Cycle&#10;0xf: 16 Cycle</description>
              <bitOffset>8</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SAMPCYC_CH2</name>
              <description>Sample cycle for channel 2. Set sampling time from 1 to 16 sar clock cycles.&#10;0x0: 1 Cycle&#10;0x1: 2 Cycle&#10;0x2: 3 Cycle&#10;0xf: 16 Cycle</description>
              <bitOffset>12</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SAMPCYC_CH3</name>
              <description>Sample cycle for channel 3. Set sampling time from 1 to 16 sar clock cycles.&#10;0x0: 1 Cycle&#10;0x1: 2 Cycle&#10;0x2: 3 Cycle&#10;0xf: 16 Cycle</description>
              <bitOffset>16</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SAMPCYC_CH4</name>
              <description>Sample cycle for channel 4. Set sampling time from 1 to 16 sar clock cycles.&#10;0x0: 1 Cycle&#10;0x1: 2 Cycle&#10;0x2: 3 Cycle&#10;0xf: 16 Cycle</description>
              <bitOffset>20</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SAR_CFG2</name>
          <description>SAR Configuration Register2</description>
          <addressOffset>0x0000000C</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>SAR_CLK_DIV</name>
              <description>SAR ADC reference clock div select. Select the divisor on the system clock after perscale.&#10;The sar adc clock = sysclk(16Mhz)/((CRGA.DIVSYSCLK+1)*(SAR_CLK_DIV+1)).&#10;The sar adc clock frequence must be no more than 4Mhz.&#10;The default sar adc clock: 1Mhz.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TS_SEL_CH1</name>
              <description>Temp sensor select for channel 1. 1&#39;b0: Temp sensor located in BUCK;&#10;1&#39;b1: Temp sensor located in LED.&#10;The value is only valid when Temp Sensor differential channel of CH1 is selected.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TS_SEL_CH2</name>
              <description>Temp sensor select for channel 2. 1&#39;b0: Temp sensor located in BUCK;&#10;1&#39;b1: Temp sensor located in LED.&#10;The value is only valid when Temp Sensor differential channel of CH2 is selected.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TS_SEL_CH3</name>
              <description>Temp sensor select for channel 3. 1&#39;b0: Temp sensor located in BUCK;&#10;1&#39;b1: Temp sensor located in LED.&#10;The value is only valid when Temp Sensor differential channel of CH3 is selected.</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TS_SEL_CH4</name>
              <description>Temp sensor select for channel 4. 1&#39;b0: Temp sensor located in BUCK;&#10;1&#39;b1: Temp sensor located in LED.&#10;The value is only valid when Temp Sensor differential channel of CH4 is selected.</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TRIG_DLY</name>
              <description>Trigger delay used for non temp sensor sampling channel. Set trigger delay time from 1 to 256 sar clock cycles.</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TRIG_DLY_TS</name>
              <description>Trigger delay used for temp sensor sampling channel. Set trigger delay time from 1 to 256 sar clock cycles.</description>
              <bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>OT_CTRL_CFG</name>
          <description>Over-temperature detection control &amp; Configuration</description>
          <addressOffset>0x00000010</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>TS_CFG</name>
              <description>Choose the OT level from 90~160 degree.&#10;0x0: 160 degree&#10;0x1: 150 degree&#10;0x2: 140 degree&#10;0x3: 130 degree&#10;0x4: 120 degree&#10;0x5: 110 degree&#10;0x6: 100 degree&#10;0x7: 90 degree</description>
              <bitOffset>0</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SEL_OT_DBNC_THRES1</name>
              <description>Select OT flag debounce threshold when a 0 turns into a 1.&#10;0x0: 32us&#10;0x1: 64us&#10;0x2: 96us&#10;0x3: 128us</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SEL_OT_DBNC_THRES0</name>
              <description>Select OT flag debounce threshold when a 1 turns into a 0.&#10;0x0: 32us&#10;0x1: 64us&#10;0x2: 96us&#10;0x3: 128us</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>EN_COMPOT</name>
              <description>Enable the comparator of over temperature function.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>EN_OVERTEMP</name>
              <description>Enable over temperature sensor.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DBG_OT</name>
              <description>OT debug enable signal. Only used to test OT in debug mode.</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DBG_TS_CH</name>
              <description>Select temperature sensor channel. Only used to test OT in debug mode.</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>START_OT_DET</name>
              <description>Set 1 to launch a OT detect operation. It&#39;s a pulse signal and no need to clear it.</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>AUTO_OT_DET_ENA</name>
              <description>Auto OT detection enable.</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>ADC_SAMP_OT_ENA</name>
              <description>ADC sampling temperature sensor enable.</description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>OT_BUSY</name>
              <description>OT_BUSY. When over-temperature sensor is working, the bit is set to high.</description>
              <bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SAR_CHAN_CFG</name>
          <description>SAR Channel Configuration</description>
          <addressOffset>0x00000014</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>CHAN_SEQ_NUM</name>
              <description>Channel Sequence number. Select the sequence number of channels to be converted.&#10;0x0: CH1 only&#10;0x1: CH1-&gt;CH2&#10;0x2: CH1-&gt;CH2-&gt;CH3&#10;0x3: CH1-&gt;CH2-&gt;CH3-&gt;CH4</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CH1_SEL</name>
              <description>Channel1 Selection. Channel1 Selects.&#10;0x0: adc_vinp=adc_refp, adc_vinn=adc_refp (all shot to adc_ref(2.4V) for adc channel offset K)&#10;0x1: adc_vinp=adc_refp, adc_vinn=vref_gnd (for adc channel +gain error K)&#10;0x2: adc_vinp=vref_gnd, adc_vinn=adc_refp (for adc channel -gain error K)&#10;0x3: adc_vinp=GPIO6, adc_vinn=GPIO7,differential channel&#10;0x4: Temp Sensor differential channel&#10;0x5: adc_vinp=VDD_1V5, adc_vinn=vref_gnd&#10;0x6: adc_vinp=VDD_3V3, adc_vinn=vref_gnd&#10;0x7: adc_vinp=VDD_PRE5V(1/4), adc_vinn=vref_gnd&#10;0x8: adc_vinp=VBAT ACCURATE (gain selected by TEST_BATTERY_GAIN_CHOOSE), adc_vinn=vref_gnd&#10;0x9: adc_vinp=GPIO6, adc_vinn=vref_gnd.&#10;0xa: adc_vinp=GPIO7, adc_vinn=vref_gnd.&#10;0xb: adc_vinp=GPIO8, adc_vinn=vref_gnd.&#10;0xc: adc_vinp=GPIO1, adc_vinn=vref_gnd.&#10;0xd: adc_vinp=GPIO2, adc_vinn=vref_gnd.&#10;0xe: adc_vinp=GPIO3, adc_vinn=vref_gnd.&#10;0xf: adc_vinp=GPIO4, adc_vinn=vref_gnd.&#10;0x10: adc_vinp=GPIO5, adc_vinn=vref_gnd.&#10;0x11: adc_vinp=GPIO9, adc_vinn=vref_gnd.&#10;0x12: adc_vinp=VBUCK 5V(1/4), adc_vinn=vref_gnd.&#10;0x13: adc_vinp=VBUCK, adc_vinn=LED PN channel 0 .&#10;0x14: adc_vinp=VBUCK, adc_vinn=LED PN channel 1 .&#10;0x2a: adc_vinp=VBUCK, adc_vinn=LED PN channel 23.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>6</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CH2_SEL</name>
              <description>Channel2 Selection. Refer to Channel1 Selects.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>6</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CH3_SEL</name>
              <description>Channel3 Selection. Refer to Channel1 Selects.</description>
              <bitOffset>16</bitOffset>
              <bitWidth>6</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CH4_SEL</name>
              <description>Channel4 Selection. Refer to Channel1 Selects.</description>
              <bitOffset>24</bitOffset>
              <bitWidth>6</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TEST_BATTERY_GAIN_CHOOSE</name>
              <description>VBAT Gain Select.&#10;0: gain=1/14, vbat max 30V/14=2.14v, under ADC vref=2.4v&#10;1: gain=1/28, vbat max 30V/28=1.07v, under ADC vref=1.2v</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>ADC_DATA0</name>
          <description>ADC_DATA0,</description>
          <addressOffset>0x00000018</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>DATA0</name>
              <description>Data0 of ADC conversion</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>DATA1</name>
              <description>Data1 of ADC conversion</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>ADC_DATA1</name>
          <description>ADC_DATA1,</description>
          <addressOffset>0x0000001C</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>DATA2</name>
              <description>Data2 of ADC conversion</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>DATA3</name>
              <description>Data3 of ADC conversion</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>ADC_OT_DATA</name>
          <description>ADC_OT_DATA,</description>
          <addressOffset>0x00000020</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>DATA_OT0</name>
              <description>Data of ADC conversion for OT channel 0</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>DATA_OT1</name>
              <description>Data of ADC conversion for OT channel 1</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SAR_INT</name>
          <description>SAR Interrupts</description>
          <addressOffset>0x00000024</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>INT_SAR_DONE_ENA</name>
              <description>SAR convert done interrupt enable.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>INT_OT_ENA</name>
              <description>Over-temperature interrupt enable.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>INT_SAR_DONE_CLR</name>
              <description>SAR convert done interrupt clear.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>INT_OT_CLR</name>
              <description>Over-temperature interrupt clear.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>INT_SAR_DONE_STS</name>
              <description>SAR convert done flag status. Set by the SAR when an conversion is done.</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_OT0_STS</name>
              <description>Over-temperature flag of OT channel 0. Set when an Over-temperature happens.</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_OT1_STS</name>
              <description>Over-temperature flag of OT channel 1. Set when an Over-temperature happens.</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_SAR_DONE_IRQ</name>
              <description>SAR convert done interrupt.</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INT_OT_IRQ</name>
              <description>Over-temperature interrupt.</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>SPI</name>
      <version>B0</version>
      <description>SPIM Interface registers</description>
      <groupName>SPI</groupName>
      <prependToName>SPI_</prependToName>
      <baseAddress>0x50010700</baseAddress>
      <addressBlock>
        <offset>0</offset>
        <size>0x0100</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>SPIRXDATA</name>
          <description>Serial Peripheral Rx Data Register</description>
          <addressOffset>0x00000000</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>RXDATA</name>
              <description>Rx Data buffer. Received Data Register.&#10;A read from this register will return data from current read pointer on the receive FIFO.&#10;A read from this register will increment the read pointer on the receive FIFO.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SPITXDATA</name>
          <description>Serial Peripheral Tx Data Register</description>
          <addressOffset>0x00000004</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>TXDATA</name>
              <description>Tx Data buffer. Transmit Data Register.&#10;Used for data that is to be transmitted.&#10;A write to this register will place data into the transmit FIFO and increment the write pointer for the transmit FIFO.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SPICTRL</name>
          <description>Serial Peripheral Control Register</description>
          <addressOffset>0x00000008</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>ENA_REQ</name>
              <description>SPI enable request.&#10;Enables the SPI interface.&#10;When SPI enable is deasserted the Tx and Rx FIFO&#39;s are still operable.&#10;Careful- If data is present in the Tx FIFO prior to enabling SPI, then once SPI is enabled it will begin transmitting the data present in the Tx FIFO.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>ENA_STS</name>
              <description>SPI enable status. Status of SPI enable</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>SPR</name>
              <description>Standard clock divider selection. Please refer to SPRE register for system clock.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CPHA</name>
              <description>SPI clock phase.&#10;0x0: Data is captured on clock transition from base and data is propagated on the clock transition to base&#10;0x1: Data is captured on clock transition to base and data is propagated on the clock transition from base</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CPOL</name>
              <description>SPI clock polarity (Motorola SPI Frame Format).&#10;0x0: The base value of the clock is zero&#10;0x1: The base value of the clock is one</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SCKEXT</name>
              <description>Extended clock divider.&#10;SPR - Standard Clock Rate Divider Select&#10;SPRE (SCKEXT) - Extended Clock Rate Select Bits&#10;{SPRE, SPR} = Clock Divide Result&#10;{00, 00}: System Clock / 2&#10;{00, 01}: System Clock / 4&#10;{00, 10}: System Clock / 8&#10;{00, 11}: System Clock / 32&#10;{01, 00}: System Clock / 64&#10;{01, 01}: System Clock / 16&#10;{01, 10}: System Clock / 128&#10;{01, 11}: System Clock / 256&#10;{10, 00}: System Clock / 512&#10;{10, 01}: System Clock / 1024&#10;{10, 10}: System Clock / 2048&#10;{10, 11}: System Clock / 4096&#10;{11, xx}: Reserved</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>ICNT</name>
              <description>Interrupt counter bits.&#10;0x0: Interrupt is set after every completed transfer&#10;0x1: Interrupt is set after two completed transfers&#10;0x2: Interrupt is set after three completed transfers&#10;0x3: Interrupt is set after four completed transfers</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LPBK</name>
              <description>Port wired-OR mode bit.&#10;0x0: master_in = miso&#10;0x1: master_in = mosi</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>FIFOSOFTRESET</name>
              <description>FIFO Soft Reset. FIFO Soft Reset bit (active high). Writing a one here will clear the FIFO pointers.&#10;This bit automatically clears to zero.</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SPISTATUS</name>
          <description>Serial Peripheral Status Register</description>
          <addressOffset>0x0000000C</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>XFERCNT</name>
              <description>Completed Transfer Count. Signal is set after a programmable amount of completed transfer. See SPI_CTRL register field ICNT.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>RXFIFOUF</name>
              <description>Reception FIFO underflow.&#10;0x0: underflow inactive&#10;0x1: underflow active</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>TXFIFOOF</name>
              <description>Transmit FIFO overflow.&#10;0x0: overflow inactive&#10;0x1: overflow active</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>RXFIFOEMPTY</name>
              <description>Reception FIFO empty.&#10;0x0: FIFO is NOT empty&#10;0x1: FIFO is empty</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>RXFIFOFULL</name>
              <description>Reception FIFO full.&#10;0x0: FIFO is NOT full&#10;0x1: FIFO is full</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>TXFIFOEMPTY</name>
              <description>Transmit FIFO empty.&#10;0x0: FIFO is NOT empty&#10;0x1: FIFO is empty</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>TXFIFOFULL</name>
              <description>Transmit FIFO full.&#10;0x0: FIFO is NOT full&#10;0x1: FIFO is full</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>RXFIFOCOUNT</name>
              <description>Reception FIFO Count. Signal indicates active number of bytes in the FIFO. Increments on Push. Decrements on Pop.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>TXFIFOCOUNT</name>
              <description>Transmit FIFO Count. Signal indicates active number of bytes in the FIFO. Increments on Push. Decrements on Pop.</description>
              <bitOffset>16</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SPIINTSTATUS</name>
          <description>SPI Interrupt Status</description>
          <addressOffset>0x00000010</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>INTXFERCNT</name>
              <description>SPI Transfer Count Interrupt. Interrupt is set after a programmable amount of completed transfer. See SPI_CTRL register field ICNT.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INTRXFIFOUF</name>
              <description>Reception FIFO Underflow Interrupt. Interrupt is set when Receive FIFO is empty and a read transaction occurs. (READ COLLISION)</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>INTTXFIFOOF</name>
              <description>Transmit FIFO Overflow Interrupt. Interrupt is set when Transmit FIFO is full and a write transaction occurs. (WRITE COLLISION)</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SPIINTENABLE</name>
          <description>SPI Interrupt Enable</description>
          <addressOffset>0x00000014</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>INTXFERCNTENA</name>
              <description>SPI Transfer Count Interrupt Enable.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>INTRXFIFOUFENA</name>
              <description>Reception FIFO Underflow Interrupt Enable.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>INTTXFIFOOFENA</name>
              <description>Transmit FIFO Overflow Interrupt Enable.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SPIINTCLEAR</name>
          <description>SPI Interrupt Clear</description>
          <addressOffset>0x00000018</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>INTXFERCNTCLR</name>
              <description>SPI Transfer Count Interrupt.&#10;Autoclear: includes a synchronous reset signal which clears the register on the cycle following write.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>INTRXFIFOUFCLR</name>
              <description>Reception FIFO Underflow Interrupt.&#10;Autoclear: includes a synchronous reset signal which clears the register on the cycle following write.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>INTTXFIFOOFCLR</name>
              <description>Transmit FIFO Overflow Interrupt.&#10;Autoclear: includes a synchronous reset signal which clears the register on the cycle following write.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>UART</name>
      <version>B0</version>
      <description>UART Interface registers</description>
      <groupName>UART</groupName>
      <prependToName>UART_</prependToName>
      <baseAddress>0x50010800</baseAddress>
      <addressBlock>
        <offset>0</offset>
        <size>0x0100</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>DATA</name>
          <description>Data</description>
          <addressOffset>0x00000000</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>DATABYTE</name>
              <description>Data. Used for both received data(ONLY bit0~7 are available) and data that is to be transmitted(bit0~8 are available):&#10;Transmit: the MSB-bit[8] is only available for Transmitter, and it indicates this data used for sending BREAK or Not&#10;1&#39;b1 : this DATA is used for sending BREAK;&#10;1&#39;b0 : this DATA is used for sending Normal Data.&#10;Receive: the MSB-bit[7] indicates the mode Match Address:&#10;1&#39;b0 : Normal mode, the following Rxd Datas will be received with the condition of 7bits-[6:0] matched;&#10;1&#39;b1 : Broadcast mode, the following Rxd Datas will be received without the condition of 7bits-[6:0] matched.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>9</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DATARECEIVESTATUS</name>
              <description>Data Receive Status. Mirror for DATA_RECEIVE_STATUS:&#10;This register contains the receive status associated with the current byte read from the UART_DATA register.&#10;The Data Receive Status register is updated only after a read from the UART_DATA register.&#10;Example- Read UART_DATA byte first. Then read UART_DATA_RECEIVE_STATUS register second.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>UARTDATARECEIVESTATUS</name>
          <description>Data Receive Status</description>
          <addressOffset>0x00000004</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>FRAMEERROR</name>
              <description>Framing Error. When this bit is set to 1, it indicates that the received byte did not have a valid stop bit (a valid stop bit is 1).</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>PARITYERROR</name>
              <description>Parity Error. When this bit is set to 1, it indicates that the parity of the received data character does not match the parity selected as defined by bits 2 and 7 of the UARTLCR_H register.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>BREAKERROR</name>
              <description>Break Error. This bit is set to 1 if a break condition was detected, indicating that the received data input was held LOW for longer than a full-word transmission time (defined as start, data, parity, and stop bits).</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>MSGCTRL</name>
          <description>Message control</description>
          <addressOffset>0x00000008</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>ENABLE</name>
              <description>Enable. Set to enable the UART</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>ENABLE_STS</name>
              <description>Enable status. Status of UART enable</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>UFIFOSOFTRESET</name>
              <description>FIFO SOFT RESET. Resets FIFO pointers to zero and initializes FIFO contents to zero&#10;Autoclear: includes a synchronous reset signal which clears the register on the cycle following write.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>RXXFERCNTCLR</name>
              <description>RX Transfer Counter Clear. Clear RX Multi Transfer Counter to zero&#10;Autoclear: includes a synchronous reset signal which clears the register on the cycle following write.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>TXXFERCNTCLR</name>
              <description>TX Transfer Counter Clear. Clear TX Multi Transfer Counter to zero&#10;Autoclear: includes a synchronous reset signal which clears the register on the cycle following write.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>ENA_ADDR_MATCH</name>
              <description>Set to enable Address Match</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>MAX_BYTES_RXD</name>
              <description>Set Max Byte number of DATA in a rxd frame&#10;0x0: 15-Bytes&#10;0x1: 31-Bytes&#10;0x2: 63-Bytes&#10;0x3: 127-Bytes</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SIZE</name>
              <description>Transmission word size.&#10;0x0: 5-bit(only available for Receive mode)&#10;0x1: 6-bit(only available for Receive mode)&#10;0x2: 7-bit(available for Receive and Transmit mode)&#10;0x3: 8-bit(available for Receive and Transmit mode)</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>STOP</name>
              <description>Stop bit control.&#10;0x0: One stop bit&#10;0x1: If a 5-bit transmission it selects 1.5 stop bits, otherwise 2 stop bits (6, 7 &amp; 8 bits)</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PARENA</name>
              <description>Parity enable. Set to enable parity (see PARODD for odd/even)</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PARODD</name>
              <description>Odd parity.&#10;0x0: ODD Parity&#10;0x1: EVEN parity</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>STICKENA</name>
              <description>Sticky parity enable. Set to enable sticky parity</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LOOPENA</name>
              <description>Loopback enable. Set to enable loopback</description>
              <bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>ADDR_MATCH</name>
              <description>Match Address. Match Address, Only 7bit is available</description>
              <bitOffset>24</bitOffset>
              <bitWidth>7</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>UARTINT</name>
          <description>UART Interrupts</description>
          <addressOffset>0x0000000C</addressOffset>
          <size>32</size>
          <access>read-write</access>
