    <peripheral>
      <name>PMUAPRE5V</name>
      <version>B0</version>
      <description>Power Management Unit of 5V domain</description>
      <groupName>PMUAPRE5V</groupName>
      <prependToName>PMUAPRE5V_</prependToName>
      <baseAddress>0x50015000</baseAddress>
      <addressBlock>
        <offset>0</offset>
        <size>0x1000</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>RETAIN0</name>
          <description>Retained data 0</description>
          <addressOffset>0x00000000</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>RETAIN0</name>
              <description>Firmware scratch register 0. Only reset at power-on (e.g contents retained in Hibernate mode and retained despite any hard or soft resets)</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>CFG_ACCESS</name>
          <description>5V domain&#39;s configuration regs access</description>
          <addressOffset>0x00000004</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>CFG_ACCESS_KEY</name>
              <description>Write the value 0xB to this register to enable &#39;trim access&#39; (which allows write access to various trim settings and production test options). Write any other value to disable trim access.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CFG_ACCESS_ENABLED</name>
              <description>A status flag that is set when 5V domain&#39;s configuration regs access is enabled</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>CFG_LOCK</name>
              <description>Set Only bit. Write 1 to this bit to lock CFG_CODE bits.</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>LIN_SLEEP_GF</name>
          <description>LINS Glitch Filter Configuration in active mode.</description>
          <addressOffset>0x00000008</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>LINS_RXD_HIGH_RST_ENA</name>
              <description>Enable signal that LINs RXD glitch filter at sleep mode is asynchronous reset by high of LINs_RXD.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LINS_SLEEP_GF_THRES0</name>
              <description>LINS RXD glitch filter threshold for 1 to 0, detect &#39;0&#39; width of (T_clk_lf*resetvalue = 4us*3 = 12[us]</description>
              <bitOffset>8</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LINS_SLEEP_GF_THRES1</name>
              <description>LINS RXD glitch filter threshold for 0 to 1, detect &#39;1&#39; width of (T_clk_lf*resetvalue = 4us*3 = 12[us]</description>
              <bitOffset>12</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LINM_RXD_HIGH_RST_ENA</name>
              <description>Enable signal that LINs RXD glitch filter at sleep mode is asynchronous reset by high of LINs_RXD.</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LINM_SLEEP_GF_THRES0</name>
              <description>LINM RXD glitch filter threshold for 1 to 0, detect &#39;0&#39; width of (T_clk_lf*resetvalue = 4us*3 = 12[us]</description>
              <bitOffset>24</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LINM_SLEEP_GF_THRES1</name>
              <description>LINM RXD glitch filter threshold for 0 to 1, detect &#39;1&#39; width of (T_clk_lf*resetvalue = 4us*3 = 12[us]</description>
              <bitOffset>28</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>LIN_WUP</name>
          <description>LIN Wakeup Control,</description>
          <addressOffset>0x0000000C</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>LINS_WUP_DETECT_THRES</name>
              <description>LIN Slave Wakeup Detection Threshold. Threshold setting(LF_CLK_PREDIV clock cycls) of lin wakeup signal. For instace, if target threshold is 150us@LF_CLK_PREDIV=250KHz, WUP_DETECT_THRES = 150/(1000/250)-1.&#10;NOTE: When the chip uses the LINs wakeup logic in pre5v domain(PMU_SFRS-&gt;CTRL.PD1V5_ENA_HIBERNATE=0x0), the write operation of this register takes effect by IOCTRLA_SFRS-&gt;LIN.UPDATE</description>
              <bitOffset>2</bitOffset>
              <bitWidth>6</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LINS_BUS_INACTIVE</name>
              <description>LIN Slave Bus Inactivity Time. NOTE: When the chip uses the LINs bus idle detection in pre5v domain(PMU_SFRS-&gt;CTRL.PD1V5_ENA_HIBERNATE=0x0), the write operation of this register takes effect by IOCTRLA_SFRS-&gt;LIN.UPDATE</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LINS_BUS_DOMN_RLS_WUP_ENA</name>
              <description>LIN Slave Bus Dominant Release Wakeup Enable. Set to trigger lin wakeup if bus dominant condition is released after BUS_IDLE_TIMEOUT_DOMINANT is detected.</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LINS_BUS_IDLE_TO_DOMN</name>
              <description>Dominant Bus Idle Timeout. The bit is set by the lin core if LIN is in hardware mode &amp; the bus is stuck at dominant inactivity state for 4s~10s. Any bus transition will clear this bit. LIN Slave&#39;s pullup will be disabled when it is set.</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>LINM_WUP_DETECT_THRES</name>
              <description>LIN Master Wakeup Detection Threshold. Threshold setting(LF_CLK_PREDIV clock cycls) of lin wakeup signal. For instace, if target threshold is 150us@LF_CLK_PREDIV=250KHz, WUP_DETECT_THRES = 150/(1000/250)-1.&#10;NOTE: When the chip uses the LINs wakeup logic in pre5v domain(PMU_SFRS-&gt;CTRL.PD1V5_ENA_HIBERNATE=0x0), the write operation of this register takes effect by IOCTRLA_SFRS-&gt;LIN.UPDATE</description>
              <bitOffset>18</bitOffset>
              <bitWidth>6</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LINM_BUS_INACTIVE</name>
              <description>LIN Master Bus Inactivity Time. NOTE: When the chip uses the LINs bus idle detection in pre5v domain(PMU_SFRS-&gt;CTRL.PD1V5_ENA_HIBERNATE=0x0), the write operation of this register takes effect by IOCTRLA_SFRS-&gt;LIN.UPDATE</description>
              <bitOffset>24</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LINM_BUS_DOMN_RLS_WUP_ENA</name>
              <description>LIN Master Bus Dominant Release Wakeup Enable. Set to trigger lin wakeup if bus dominant condition is released after BUS_IDLE_TIMEOUT_DOMINANT is detected.</description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LINM_BUS_IDLE_TO_DOMN</name>
              <description>Dominant Bus Idle Timeout. The bit is set by the lin core if LIN is in hardware mode &amp; the bus is stuck at dominant inactivity state for 4s~10s. Any bus transition will clear this bit. LIN Master&#39;s pullup will be disabled when it is set.</description>
              <bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>LINS</name>
          <description>LIN slave Pin Control.</description>
          <addressOffset>0x00000010</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>LINS_PU30K_ENA</name>
              <description>LIN 30K pullup enable.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LINS_RXENA</name>
              <description>LIN receive enable.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SWON</name>
              <description>LIN Dual Mode Switch On. Set to enable dual-mode lin switch. Only reset by power-on sequence. This bit can be locked by setting SWON_LOCK.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SWOFF_TIMEOUT</name>
              <description>Switch off in dominant TimeOut condition. Set to disconnect lin switch in case that lin bus is shorted to ground(Bus idle dominant timeout is detected) for saving power. LIN Switch will be recovered automatically if bus idle dominant timeout is released by any bus activity. Only reset by power-on sequence.</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LINS_PUOFF_TIMEOUT</name>
              <description>LINS Pullup Disable in dominant TimeOut condition. Set to disable LINS 30K pullup in case that lin bus is shorted to ground(Bus idle dominant timeout is detected) for saving power. LINS Pullup will be recovered automatically if bus idle dominant timeout is released by any bus activity. Only reset by power-on sequence.</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LINS_RX_BIAS_BOOST</name>
              <description>adjust rise delay from LIN_IN to Input of LINS Controller.&#10;0x0: 2.323 us&#10;0x1: 1.344 us&#10;0x2: 0.968 us&#10;0x3: 0.767 us</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LINS_TX_BIAS_BOOST</name>
              <description>LIN Slave IO TX Bias select. Select LIN IO TX Pull Down Current.&#10;0x0: ~61 mA&#10;0x1: ~83 mA&#10;0x2: ~105 mA&#10;0x3: ~126 mA</description>
              <bitOffset>10</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LIN_TX_S_DT</name>
              <description>LIN Slave duty cycle adjust.&#10;0x0: duty cycle = 0.488&#10;0x1: duty cycle = 0.492&#10;0x2: duty cycle = 0.494&#10;0x3: duty cycle = 0.495&#10;0x4: duty cycle = 0.497&#10;0x5: duty cycle = 0.5&#10;0x6: duty cycle = 0.507&#10;0x7: duty cycle = 0.529</description>
              <bitOffset>13</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LIN_TX_S_SL</name>
              <description>LIN Slave TX driver slew rate select. Slew from 40%*Vbat to 60%*Vbat @Vbat=13V,Cbus=1nF.&#10;0000 -&gt; 1110: 1.07V/us ~ 4.71V/us, step is about 0.26V/us&#10;1111: about 10V/us for fast LIN mode</description>
              <bitOffset>16</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LIN_DBG</name>
              <description>LIN DEBUG. one hot code&#10;0001: select lin_tx_s_duty_ibg1up_tp to gpio2 analog channel&#10;0010: select lin_tx_s_slope_ibg1up_tp to gpio2 analog channel&#10;0100: select lin_tx_m_duty_ibg1up_tp to gpio2 analog channel&#10;1000: select lin_tx_m_slope_ibg1up_tp to gpio2 analog channel</description>
              <bitOffset>24</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SWON_LOCK</name>
              <description>SWON Lock Bit.</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>LINM</name>
          <description>LIN Master Pin Control.</description>
          <addressOffset>0x00000014</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>LINM_PU1K_ENA</name>
              <description>LIN 1K pullup enable.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LINM_RXENA</name>
              <description>LIN receive enable.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LINM_PUOFF_TIMEOUT</name>
              <description>LINM 1K Pullup disable in dominant TimeOut condition. Set to disable LINM 1K pullup in case that lin bus is shorted to ground(Bus idle dominant timeout is detected) for saving power. LINS 1K Pullup will be recovered automatically if bus idle dominant timeout is released by any bus activity. If this bit is set &amp; SWON = 1, LINM&#39;s 30K pullup will be enabled for preventing bus floating. Only reset by power-on sequence.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LINM_RX_BIAS_BOOST</name>
              <description>adjust rise delay from LIN_OUT to Input of LINM Controller.&#10;0x0: 2.323 us&#10;0x1: 1.344 us&#10;0x2: 0.968 us&#10;0x3: 0.767 us</description>
              <bitOffset>19</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LINM_TX_BIAS_BOOST</name>
              <description>LIN Master IO TX Bias select. Select LIN IO TX Pull Down Current.&#10;0x0: ~61 mA&#10;0x1: ~83 mA&#10;0x2: ~105 mA&#10;0x3: ~126 mA</description>
              <bitOffset>21</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LIN_TX_M_DT</name>
              <description>LIN Master duty cycle adjust.&#10;0x0: duty cycle = 0.488&#10;0x1: duty cycle = 0.492&#10;0x2: duty cycle = 0.494&#10;0x3: duty cycle = 0.495&#10;0x4: duty cycle = 0.497&#10;0x5: duty cycle = 0.5&#10;0x6: duty cycle = 0.507&#10;0x7: duty cycle = 0.529</description>
              <bitOffset>24</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LIN_TX_M_SL</name>
              <description>LIN Master TX driver slew rate select. Slew from 40%*Vbat to 60%*Vbat @Vbat=13V,Cbus=1nF.&#10;0000 -&gt; 1110: 1.07V/us ~ 4.71V/us, step is about 0.26V/us&#10;1111: about 10V/us for fast LIN mode</description>
              <bitOffset>27</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>CTRL</name>
          <description>PMU Debug Control.</description>
          <addressOffset>0x00000018</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>PD1V5_ENA_HIBERNATE</name>
              <description>enable of 1V5 Power Domain at Hibernate mode. set to enable the 1V5 Power Domain at Hibernate mode, this mode is defined as DEEPSLEEP mode.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>OPT_EN_LP</name>
              <description>Set to enable of low power mode for BG_TOP at Deepsleep Mode.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DBG_EN_LP_BG</name>
              <description>Set to enable of low power mode for BG_TOP at PMU debug mode.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DBG_EN_LP_1V5</name>
              <description>Set to enable of low power mode for LDO1V5 at PMU debug mode.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DBG_EN_LP_5V0</name>
              <description>Set to enable of low power mode for LDO5V0 at PMU debug mode.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DBG_EN_LP_BOR1V5</name>
              <description>Set to enable of low power mode for BOR1V5 at PMU debug mode.</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DBG_DIS_LDO_1V5</name>
              <description>Debug Contrl of dis_ldo_1v5 at PMU debug mode.(Not Use)</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DBG_EN_LDO_3V3</name>
              <description>NOTE:Don&#39;t use.Debug Contrl of en_ldo_3v3 at PMU debug mode.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DBG_EN_BOR_1V5</name>
              <description>Debug Contrl of dis_bor_1v5 at PMU debug mode.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DBG_EN_BOR_3V3</name>
              <description>Debug Contrl of dis_bor_3v3 at PMU debug mode.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DBG_DISCHARGE_1V5</name>
              <description>1V5 LDO Debug Mode:&#10;a. Set &#39;0&#39; to test 1V5-LDO function;&#10;b. Set &#39;1&#39; to test 1V5-LDO Discharge Circuit.</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DBG_DISCHARGE_3V3</name>
              <description>3V3 LDO Debug Mode:&#10;a. Set &#39;0&#39; to test 3V3-LDO function;&#10;b. Set &#39;1&#39; to test 3V3-LDO Discharge Circuit.</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DBG_ISO</name>
              <description>NOTE:Don&#39;t use. Debug Contrl of isolation of domain 1V5 to domain PRE5V at PMU debug mode.</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>OVERTEMP_ENA</name>
              <description>OverTemp Monitor Enable bit.</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>VDD1V5_LDO_CHOOSE</name>
              <description>1.5V LDO Mode selection.&#10;NOTE: This register is not used by Analog PMU&#10;0x0: choose Capless LDO&#10;0x1: choose Caps LDO</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TRIM_BG_V2I</name>
              <description>Trim the BG V2I which output the buffered reference voltage.</description>
              <bitOffset>16</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TRIM_BG</name>
              <description>Trim the BG core 1.21415V output voltage&#10;(1) The voltage range before trimming is 1.16797V ~ 1.26337V.&#10;(2) The trim ratio 1/1.4811.&#10;(3) The voltage is 1.21455V while TRIM_BG == 0x0.&#10;at PMU debug mode</description>
              <bitOffset>20</bitOffset>
              <bitWidth>6</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DBG_ACCESS_KEY</name>
              <description>Write the value 0x5 to this register to enable debug options. Write any other value to disable the debug options.</description>
              <bitOffset>26</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DBG_ACCESS_ENABLED</name>
              <description>A status flag that is set when debug access is enabled</description>
              <bitOffset>30</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>DBG_LOCK</name>
              <description>Set Only bit. Set this bit to lock DBG_CODE bits.</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>BOR</name>
          <description>BOR configuration</description>
          <addressOffset>0x0000001C</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>S_BOR_3V3</name>
              <description>BOR 3v3 threshold. Select the BOR threshold voltage level for the 3v3 regulator, Following typical value can be used as reference:&#10;NOTE: The write operation will be locked by BOR_SFRS-&gt;BOR_LOCK&#10;0x0: Vr: 2.223 V, Vf: 2.765 V,&#10;0x1: Vr: 2.288 V, Vf: 2.825 V,&#10;0x2: Vr: 2.358 V, Vf: 2.895 V,&#10;0x3: Vr: 2.428 V, Vf: 2.975 V,&#10;0x4: Vr: 2.503 V, Vf: 3.055 V(default),&#10;0x5: Vr: 2.583 V, Vf: 3.135 V,&#10;0x6: Vr: 2.668 V, Vf: 3.225 V,&#10;0x7: Vr: 2.763 V, Vf: 3.315 V,</description>
              <bitOffset>0</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>S_BOR_1V5</name>
              <description>BOR 1v5 threshold. Select the BOR threshold voltage level for the 1v5 regulator. Following typical value can be used as reference:&#10;NOTE: The write operation will be locked by BOR_SFRS-&gt;BOR_LOCK&#10;0x0: Vr: 1.135 V, Vf: 1.055 V,&#10;0x1: Vr: 1.165 V, Vf: 1.095 V,&#10;0x2: Vr: 1.215 V, Vf: 1.135 V,&#10;0x3: Vr: 1.255 V, Vf: 1.175 V,&#10;0x4: Vr: 1.305 V, Vf: 1.215 V,&#10;0x5: Vr: 1.355 V, Vf: 1.265 V(default),&#10;0x6: Vr: 1.405 V, Vf: 1.315 V,&#10;0x7: Vr: 1.465 V, Vf: 1.375 V,</description>
              <bitOffset>4</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BOR_3V3_ACTION</name>
              <description>BOR 3v3 action. Defines the consequences of brown-out condition on the 3v3 supply being detected by the hardware.&#10;NOTE: The write operation will be locked by BOR_SFRS-&gt;BOR_LOCK&#10;0x1: IRQ generated&#10;0x0: Hard reset generated</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BOR_1V5_ACTION</name>
              <description>BOR 1v5 action. Defines the consequences of brown-out condition on the 1v5 supply being detected by the hardware.&#10;NOTE: The write operation will be locked by BOR_SFRS-&gt;BOR_LOCK&#10;0x1: IRQ generated&#10;0x0: Hard reset generated</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BOR_LOCK</name>
              <description>Set Only bit. Set this bit to lock BOR_ACTION &amp; S_BOR bits.</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BOR_3V3_FLAG</name>
              <description>BOR 3v3 flag. Set by the hardware when a brownout of the 3.3V supply is detected.</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>BOR_1V5_FLAG</name>
              <description>BOR 1v5 flag. Set by the hardware when a brownout of the 1.5V supply is detected.</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>BOR_3V3_FLAG_CLR</name>
              <description>BOR 3v3 clear. Set to clear the 3.3V brownout detected flag</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>BOR_1V5_FLAG_CLR</name>
              <description>BOR 1v5 clear. Set to clear the 1.5V brownout detected flag</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>BORDEGLITCH</name>
          <description>BOR Deglitch.</description>
          <addressOffset>0x00000020</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>ENA_BOR1V5_DEGLITCH</name>
              <description>enable of BOR1V5 deglitch.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SEL_BOR1V5_NEG_DEGLITCH</name>
              <description>select the deglitch width of BOR1V5 negedge.&#10;0x0: 16us Selected&#10;0x1: 32us Selected&#10;0x2: 64us Selected&#10;0x3: 128us Selected</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SEL_BOR1V5_POS_DEGLITCH</name>
              <description>select the deglitch width of BOR1V5 posedge.&#10;0x0: 16us Selected&#10;0x1: 32us Selected&#10;0x2: 64us Selected&#10;0x3: 128us Selected</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>ENA_BOR3V3_DEGLITCH</name>
              <description>enable of BOR3V3 deglitch.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SEL_BOR3V3_NEG_DEGLITCH</name>
              <description>select the deglitch width of BOR3V3 negedge.&#10;0x0: 16us Selected&#10;0x1: 32us Selected&#10;0x2: 64us Selected&#10;0x3: 128us Selected</description>
              <bitOffset>12</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SEL_BOR3V3_POS_DEGLITCH</name>
              <description>select the deglitch width of BOR3V3 posedge.&#10;0x0: 16us Selected&#10;0x1: 32us Selected&#10;0x2: 64us Selected&#10;0x3: 128us Selected</description>
              <bitOffset>14</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>CLK_CTRL</name>
          <description>Clock controls for 5V(always on) domain.</description>
          <addressOffset>0x00000024</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>PMUA_PRE5V_CLKMUX_SEL</name>
              <description>5V domain Clock select. Used to switch between the fast and slow 5v domain clocks&#10;0x0: Slow clock&#10;0x1: Fast clock</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>EN_HIGH_BW_LF_RC</name>
              <description>set to enable to increase internal comparator bandwidth</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TRIM_LF_RC</name>
              <description>LF RC oscillator trim. Following value only used as a reference:(the trim freq is non-linear)&#10;0x0: freq(250k)=141.1Khz&#10;0xa2: freq(250k)=250.0Khz&#10;0xa4: freq(250k)=256.0Khz&#10;0xff: freq(250k)=441.7Khz</description>
              <bitOffset>8</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CLK_LF_RC_STS</name>
              <description>Slow oscillator status. Will be high when the Low Frequency oscillator is selected</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>CLK_HF_RC_STS</name>
              <description>Fast oscillator status. Will be high when High Frequency oscillator is enabled</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>DFT</name>
          <description>DFT</description>
          <addressOffset>0x00000028</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>DFT_CODE</name>
              <description>Write the value 0x1C to this register to Unlock &#39;Scan Test Mode&#39;.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>DFT_LOCK</name>
              <description>Set Only bit. Write 1 to this bit to lock DFT_CODE config bits.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DFT_ACCESS_ENABLED</name>
              <description>A status flag that is set when DFT access is enabled.</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>DFT_TESTMODE_START</name>
              <description>Puts the ASIC into DFT testmode. Once the start bit is set, the I/O configuration will switch from Application mode to DFT Test Mode. The General Purpose I/Os will be configured as a JTAG interface. Once Test Mode is enabled, the ASIC will be boundary terminated and the processor will lose the ability to communicate with any ASIC peripherals. A chip power cycle is required to get out of the DFT test mode. Test Mode Enable state.</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>TIMER0</name>
      <version>B0</version>
      <description>General purpose timer 0 registers</description>
      <groupName>TIMER0</groupName>
      <prependToName>TIMER0_</prependToName>
      <baseAddress>0x50020000</baseAddress>
      <addressBlock>
        <offset>0</offset>
        <size>0x0008</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>COUNT</name>
          <description>Timer Counter Register</description>
          <addressOffset>0x00000000</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>COUNT</name>
              <description>Count. Initial counter value. The timer will count from this value to 0xFFFFFFFF and roll over to 0x00000000. At this point it will generate an interrupt if enabled. The interrupt routine is responsible for reloading the value if needed as this timer does not auto-reload the original content.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>CFG</name>
          <description>Timer Control Register</description>
          <addressOffset>0x00000004</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <fields>
            <field>
              <name>ENA</name>
              <description>Enable. This bit starts/stops the timer:&#10;1 = Timer Running&#10;0 = Timer Inactive</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
