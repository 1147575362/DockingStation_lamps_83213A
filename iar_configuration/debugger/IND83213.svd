            <field>
              <name>LINSTXDTIMEOUTDOMINANT</name>
              <description>Tx Dominant Timeout. The bit is set by LINS TxD monitor if LINS&#39;s TxD is stuck at dominant output for 64ms. A dominant to recessive transition of the TxD will clear this bit. LIN&#39;s TX will be disabled automatically when this bit is set.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
